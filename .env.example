# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit secrets.

# Admin panel credentials. If unset, the defaults in lib/auth.ts apply.
ADMIN_USER=admin
ADMIN_PASS=change-me-to-something-strong

# Random string used to sign the session cookie. 32+ chars recommended.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=replace-with-a-long-random-string
